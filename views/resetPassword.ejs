<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content="AnimeList, votre partenaire pour la création de sites web modernes, performants et la réparation informatique.">
    <meta name="keywords" content="site web, création de site, développeur web, réparation PC, informatique, AnimeList, web design">
    <meta name="author" content="AnimeList">
    <meta name="robots" content="index, follow">
    <title>AnimeList - Réinitialisation</title>
    <link rel="icon" href="/ico/AnimeList.ico" type="image/x-icon">
    <link rel="stylesheet" href="/css/resetPassword.css" />
  </head>
  <body>
    <div class="reset-container">
      <h2 class="reset-title">Réinitialisation du mot de passe</h2>
      <div class="reset-box">
        <% if (!token) { %>
          <!-- Formulaire 1 -->
          <form class="reset-form" action="/resetpassword" method="POST">
            <div class="input-box">
              <input
                type="email"
                name="email"
                id="email"
                required
                placeholder="Entrez votre email"
              />
            </div>
            <button type="submit" class="reset-btn" aria-label="Envoyer la demande de réinitialisation">📩 Envoyer</button>
          </form>
        <% } else { %>
          <!-- Formulaire 2 -->
          <form
            class="reset-form"
            action="/resetpassword/<%= token %>"
            method="POST"
          >
            <div class="input-box">
              <input
                type="password"
                name="newPassword"
                id="newPassword"
                required
                placeholder="Nouveau mot de passe"
                pattern="^(?=.*[A-Z])(?=.*[!@#$%^&*]).{8,}$"
                title="Le mot de passe doit contenir au moins 8 caractères, au moins 1 majuscule et 1 caractère spécial (!@#$%^&*)."
              />
            </div>
            <div class="input-box">
              <input
                type="password"
                name="confirmNewPassword"
                id="confirmNewPassword"
                required
                placeholder="Confirmez le mot de passe"
                pattern="^(?=.*[A-Z])(?=.*[!@#$%^&*]).{8,}$"
                title="Le mot de passe doit contenir au moins 8 caractères, au moins 1 majuscule et 1 caractère spécial (!@#$%^&*)."
              />
            </div>
            <button type="submit" class="reset-btn">🔄 Changer</button>
          </form>
        <% } %>
        <p class="back-to-login">
          <a href="/login">⬅ Retour à la connexion</a>
        </p>
        <p class="notice">⚠ <strong>Limité à 2 demandes</strong> par période de 24h.</p>
        <p class="notice">⚠ <strong>Vérifiez dans vos spams.</strong></p>
      </div>
    </div>
  </body>
</html>
