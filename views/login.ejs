<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="AnimeList, votre partenaire pour la création de sites web modernes, performants et la réparation informatique.">
    <meta name="keywords" content="site web, création de site, développeur web, réparation PC, informatique, AnimeList, web design">
    <meta name="author" content="AnimeList">
    <meta name="robots" content="index, follow">
    <title>AnimeList - Connexion</title>
    <link rel="icon" href="/ico/AnimeList.ico" type="image/x-icon">
    <link rel="stylesheet" href="/css/login.css" />
  </head>
  <body class="login-body">
    <div class="container">
      <div class="login-box">
        <h2 class="login-title">BookWorld99</h2>
        <form action="/login" method="POST">
          <div class="input-box">
            <input
              type="email"
              name="email"
              id="email"
              required
              class="login-input"
            />
            <label>Email</label>
          </div>
          <div class="input-box">
            <input
              type="password"
              name="password"
              id="password"
              required
              class="login-input"
            />
            <label>Mot de passe</label>
          </div>
          <div class="forgot-password">
            <a href="/resetpassword" class="forgot-link">Mot de passe oublié ?</a>
          </div>
          <button type="submit" class="btn login-btn">Se connecter</button>
        </form>
        <div class="signup-link">
          <p>
            Pas encore inscrit ?
            <a href="/register" class="signup-link-text">Créer un compte</a>
          </p>
          <p>
            pas envie d'un compte ? 
            <a href="/" class="signup-link-text">home</a>
          </p>
        </div>
      </div>
    </div>
  </body>
</html>
