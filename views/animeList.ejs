<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <meta name="description" content="Website-2025, votre partenaire pour la création de sites web modernes, performants et la réparation informatique.">
  <meta name="keywords" content="site web, création de site, développeur web, réparation PC, informatique, website-2025, web design">
  <meta name="author" content="Website-2025">
  <meta name="robots" content="index, follow">
  <title><%= title %> • AnimeList</title>
  <link rel="stylesheet" href="/css/navbar.css"/>
  <link rel="stylesheet" href="/css/footer.css"/>
  <link rel="stylesheet" href="/css/animeList.css">
  <link rel="icon" href="/ico/website-2025.ico" type="image/x-icon">
  <link rel="stylesheet" href="/css/cookieBanner.css">
</head>
<body>

  <%- include('partials/navbar') %>

  <main class="al-wrapper">
    <header class="al-header">
      <h1>Ma liste d'animes</h1>
      <p class="al-sub">Ajoute, cherche et parcours par ordre alphabétique.</p>
    </header>

    <% if (session.role === "admin") { %>
      <!-- Formulaire d'ajout -->
      <section class="al-card al-form">
        <h2>Ajouter un anime</h2>
        <form id="animeForm" enctype="multipart/form-data" autocomplete="off">
          <div class="grid-2">
            <label>Nom
              <input type="text" name="name" required />
            </label>

            <label>Année
              <input type="number" name="year" placeholder="2025" min="1900" max="2100" />
            </label>
          </div>

          <div class="grid-2">

            <label>Genres (séparés par des virgules)
              <input type="text" name="genres" placeholder="Action, Aventure, ..." />
            </label>
          </div>

          <label>Description
            <textarea name="description" rows="4" placeholder="Résumé rapide..."></textarea>
          </label>

          <label>Image (obligatoire)
            <input type="file" name="image" accept="image/*" required />
          </label>

          <button type="submit" class="al-btn">Ajouter</button>
          <p id="formMsg" class="al-msg" aria-live="polite"></p>
        </form>
      </section>
    <% } %> 

    <!-- Liste / rendu -->
    <section class="al-card">
      <div class="al-toolbar">
        <h2 class="m0">Animes</h2>
        <div class="al-count"><span id="count">0</span> résultat(s)</div>
      </div>

      <ul id="animeList" class="al-grid"></ul>
      <template id="animeItemTpl">
        <li class="al-item">
          <% if (session.role === "admin") { %>
            <button class="al-del" title="Supprimer" aria-label="Supprimer">×</button>
          <% } %>
          <article class="al-article">
            <img class="al-cover" alt="" loading="lazy" decoding="async" />

            <% if (session.role === "admin") { %>
              <!-- 🔽 Bouton "En cours de visionnage" -->
              <button class="al-watch" type="button" aria-pressed="false">
                En cours de visionnage
              </button>
            <% } %>  

            <div class="al-info">
              <h3 class="al-name"></h3>
              <p class="al-meta"></p>
              <p class="al-genres"></p>
              <p class="al-status"></p>
              <p class="al-desc"></p>
            </div>
          </article>
        </li>
      </template>

    </section>
  </main>

  <%- include('partials/footer') %>
  <%- include('partials/cookieBanner') %>

  <script src="/js/animeList.js" defer></script>
  <script src="/js/animeSearch.js" defer></script>
  <script src="/js/avatarMenu.js" defer></script>
  <script src="/js/animeWatching.js" defer></script>

</body>
</html>
